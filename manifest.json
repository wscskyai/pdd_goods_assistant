{
  "manifest_version": 3,
  "name": "PDD Goods Assistant",
  "version": "0.1.0",
  "description": "管理拼多多商品信息编辑与发货辅助（基础脚手架）",
  "action": {
    "default_title": "PDD 助手",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "src/options/options.html",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://mms.pinduoduo.com/print/goods-setting*"],
  "content_scripts": [
    {
      "matches": ["https://mms.pinduoduo.com/print/goods-setting*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
